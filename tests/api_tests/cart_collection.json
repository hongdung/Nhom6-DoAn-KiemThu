{
  "info": {
    "name": "D&M Fashion - API Cart Edge Cases",
    "description": "Bộ Collection cho phép kiểm thử BVA trực tiếp thông qua HTTP Request độc lập tới REST API /api/cart",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "PATCH /api/cart/:productId - Vượt Max Boundary (11)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status is 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Verify quantity clamped to 10\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.items.length).to.be.above(0);",
              "    pm.expect(jsonData.items[0].quantity).to.eql(10);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"quantity\": 11\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/cart/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cart", "1"]
        }
      }
    },
    {
      "name": "DELETE /api/cart/:productId - Xoá Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Validation empty Array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.items).to.be.an('array');",
              "    var id1Exists = jsonData.items.some(item => item.productId === 1);",
              "    pm.expect(id1Exists).to.be.false;",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/cart/1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cart", "1"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://dm-fashion-apparel.onrender.com",
      "type": "string"
    }
  ]
}
