<%- include('partials/head') %>
<%- include('partials/header', { selectedCategory }) %>

<section class="section-header">
  <div>
    <p class="eyebrow">Quản lý sản phẩm</p>
    <h1>Danh sách sản phẩm</h1>
    <p>Theo dõi giá bán, tồn kho, danh mục và cập nhật nhanh các sản phẩm hiện có.</p>
  </div>
  <div class="admin-toolbar">
    <a href="/admin/categories" class="secondary-link">Quản lý danh mục</a>
    <a href="/admin/products/new" class="primary-link">Thêm sản phẩm</a>
  </div>
</section>

<%- include('partials/admin-nav') %>

<section class="table-card">
  <div class="table-header">
    <p class="eyebrow">Danh sách</p>
    <h2>Tất cả sản phẩm</h2>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Tên sản phẩm</th>
          <th>Danh mục</th>
          <th>Giá bán</th>
          <th>Giá gốc</th>
          <th>Tồn kho</th>
          <th>Nổi bật</th>
          <th>Thao tác</th>
        </tr>
      </thead>
      <tbody>
        <% products.forEach((product) => { %>
          <tr>
            <td>
              <strong><%= product.name %></strong>
              <div class="cell-subtitle">Slug: <code><%= product.slug %></code></div>
            </td>
            <td><%= product.category %></td>
            <td><%= formatCurrency(product.price) %></td>
            <td>
              <%= product.comparePrice ? formatCurrency(product.comparePrice) : 'Không có' %>
            </td>
            <td><%= product.stock %></td>
            <td>
              <span class="status-pill <%= product.featured ? 'is-active' : 'is-muted' %>">
                <%= product.featured ? 'Có' : 'Không' %>
              </span>
            </td>
            <td>
              <a href="/admin/products/<%= product.id %>/edit" class="secondary-link small-link">
                Chỉnh sửa
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
