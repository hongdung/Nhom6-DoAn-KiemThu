{
  "info": {
    "name": "D&M Fashion - Post-Login API Tests",
    "description": "Kiểm thử các API sau khi login (Cart, Checkout, Admin)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "POST /api/auth/login - Retrieve Auth Cookie",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Login successful\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"email\": \"customer@atelier.local\",\n    \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      }
    },
    {
      "name": "GET /api/admin/overview - Validate 403 for Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 403 Forbidden\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "pm.test(\"Message validation\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.message).to.eql(\"Cần quyền quản trị viên\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/admin/overview",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "overview"]
        }
      }
    },
    {
      "name": "POST /api/cart - Add Item to Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "pm.test(\"Cart has item in response\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.items.length).to.be.above(0);",
              "    pm.expect(jsonData.items[0].productId).to.eql(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"productId\": 1,\n    \"quantity\": 2\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/cart",
          "host": ["{{baseUrl}}"],
          "path": ["api", "cart"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://dm-fashion-apparel.onrender.com",
      "type": "string"
    }
  ]
}
