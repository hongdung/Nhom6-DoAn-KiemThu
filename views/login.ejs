<%- include('partials/head') %>
<%- include('partials/header', { selectedCategory }) %>

<section class="auth-grid">
  <div class="auth-copy">
    <p class="eyebrow">Tài khoản của bạn</p>
    <h1>Đăng nhập để theo dõi đơn hàng, lưu giỏ hàng và thanh toán nhanh hơn.</h1>
    <p>
      Truy cập tài khoản để cập nhật thông tin cá nhân, xem trạng thái đơn mua và tiếp tục mua sắm
      thuận tiện trên mọi thiết bị.
    </p>
  </div>
  <form action="/login" method="post" class="auth-form">
    <label>
      Email
      <input type="email" name="email" placeholder="ban@email.com" required />
    </label>
    <label>
      Mật khẩu
      <input type="password" name="password" placeholder="Nhập mật khẩu của bạn" required />
    </label>
    <button type="submit">Đăng nhập</button>
  </form>
</section>

<%- include('partials/footer') %>
